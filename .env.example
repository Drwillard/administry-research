# Database connection string (SQLAlchemy format)
# External RDS example:
#   DATABASE_URL=mysql+pymysql://user:password@your-host.rds.amazonaws.com:3306/dbname
# Bundled MySQL example:
#   DATABASE_URL=mysql+pymysql://user:password@db:3306/administry
DATABASE_URL=mysql+pymysql://user:password@db:3306/administry

# Secret salt used to anonymise client and author IDs via HMAC-SHA256.
# Set to a long, random string. Changing this will invalidate all existing anonymised keys.
ANON_SALT=change-me-to-a-long-random-secret

# Anthropic API key — required for /analyze/client/v2 (LLM note summarisation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Directory where parquet output files are written (default: ./out)
# OUT_DIR=./out

